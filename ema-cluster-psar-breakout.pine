//@version=6
//============================================================
// Indicator : EMA Cluster PSAR Breakout
// Version   : V1.0
//
// BUY Conditions
// 1. EMA 5,10,20 are clubbed
// 2. Bullish candle crosses above all EMAs
// 3. PSAR below price
//
// SELL Conditions
// 1. EMA 5,10,20 are clubbed
// 2. Bearish candle crosses below all EMAs
// 3. PSAR above price
//
//============================================================

indicator("EMA Cluster PSAR Breakout", shorttitle="EMA Cluster PSAR Breakout", overlay=true)
//========================
// Inputs
//========================

emaFastLength = input.int(5, "EMA Fast")
emaMidLength  = input.int(10, "EMA Medium")
emaSlowLength = input.int(20, "EMA Slow")

clusterPercent = input.float(0.30,
     "EMA Cluster (%)",
     step = 0.05)

psarStep = input.float(0.02, "PSAR Step")
psarMax  = input.float(0.20, "PSAR Maximum")

showBuySell = input.bool(true, "Show Signals")

telegramChatId = input.string("", "Telegram Chat ID", group = "Alerts")

//========================
// EMA Calculation
//========================

ema5  = ta.ema(close, emaFastLength)
ema10 = ta.ema(close, emaMidLength)
ema20 = ta.ema(close, emaSlowLength)

//========================
// Plot EMAs
//========================

plot(ema5,  color=color.red,   linewidth=2, title="EMA 5")
plot(ema10, color=color.green, linewidth=2, title="EMA 10")
plot(ema20, color=color.blue,  linewidth=2, title="EMA 20")

//========================
// EMA Cluster Logic
//========================

highestEMA = math.max(ema5, math.max(ema10, ema20))
lowestEMA  = math.min(ema5, math.min(ema10, ema20))

clusterDistance = (highestEMA - lowestEMA) / close * 100

emaCluster = clusterDistance <= clusterPercent

//========================
// Parabolic SAR
//========================

psar = ta.sar(psarStep, psarStep, psarMax)

plot(psar, style=plot.style_cross, color=color.orange, title="PSAR")

psarBull = psar < close
psarBear = psar > close

//========================
// BUY Logic
//========================

// Candle opens below EMA cluster
openBelow = open < lowestEMA

// Candle closes above EMA cluster
closeAbove = close > highestEMA

bullishCandle = close > open

buySignal =
     emaCluster and
     bullishCandle and
     openBelow and
     closeAbove and
     psarBull

//========================
// SELL Logic
//========================

openAbove = open > highestEMA

closeBelow = close < lowestEMA

bearishCandle = close < open

sellSignal =
     emaCluster and
     bearishCandle and
     openAbove and
     closeBelow and
     psarBear

//========================
// Plot Signals
//========================

plotshape(showBuySell and buySignal,
     title="BUY",
     style=shape.labelup,
     location=location.belowbar,
     color=color.green,
     text="BUY",
     textcolor=color.white,
     size=size.small)

plotshape(showBuySell and sellSignal,
     title="SELL",
     style=shape.labeldown,
     location=location.abovebar,
     color=color.red,
     text="SELL",
     textcolor=color.white,
     size=size.small)

//========================
// Alerts
//========================

signalType = buySignal ? "BUY" : sellSignal ? "SELL" : na

if (buySignal or sellSignal) and telegramChatId != ""
    jsonMsg = '{"chat_id":"' + telegramChatId + '","text":"' +
         signalType + " Signal on " + syminfo.ticker +
         " (" + syminfo.description + ")" +
         " Price=" + str.tostring(close) + '"}'
    alert(jsonMsg, alert.freq_once_per_bar_close)
